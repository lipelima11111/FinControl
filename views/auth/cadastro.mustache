<!DOCTYPE html>
<!-- View: formulário de cadastro (POST /cadastro) -->
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>FinControl — Cadastro</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://unpkg.com/boxicons@2.1.4/css/boxicons.min.css" rel="stylesheet">
  <link rel="stylesheet" href="/styles.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body class="auth-page">

  <div class="container-fluid g-0 min-vh-100">
    <div class="row g-0 min-vh-100">

      <div class="col-md-6 auth-panel auth-panel--brand d-none d-md-flex">
        <div class="auth-brand d-flex flex-column justify-content-between h-100 w-100">
          <div>
            <h1 class="auth-brand__title">FinControl</h1>
            <p class="auth-brand__tagline">Crie sua conta gratuita e comece hoje mesmo.</p>
          </div>
          <p class="auth-brand__footer mb-0">© 2026 FinControl — UCB Grupo 3</p>
        </div>
      </div>

      <div class="col-md-6 auth-panel auth-panel--form d-flex align-items-center justify-content-center">
        <div class="auth-form-wrapper w-100">
          <div class="auth-form-header d-md-none text-center mb-4">
            <h2 class="auth-form-title mb-0">FinControl</h2>
          </div>

          <h2 class="auth-form-title">Criar nova conta</h2>
          <p class="auth-form-subtitle">Preencha os dados abaixo para começar</p>

          {{#erro}}
            <div class="alert alert-danger py-2">{{erro}}</div>
          {{/erro}}

          <form method="POST" action="/cadastro" class="auth-form">
            <div class="mb-3">
              <label class="form-label auth-label">Nome completo</label>
              <input type="text" name="nome" class="form-control auth-input"
                placeholder="João Silva" required>
            </div>
            <div class="mb-3">
              <label class="form-label auth-label">E-mail</label>
              <input type="email" name="email" class="form-control auth-input"
                placeholder="seu@email.com" required>
            </div>
            <div class="row g-3 mb-3">
              <div class="col-md-6">
                <label class="form-label auth-label">Senha</label>
                <input type="password" name="senha" class="form-control auth-input"
                  minlength="8" placeholder="Mínimo 8 caracteres" required>
              </div>
              <div class="col-md-6">
                <label class="form-label auth-label">Confirmar senha</label>
                <input type="password" name="senha_confirmacao" class="form-control auth-input"
                  minlength="8" placeholder="••••••••" required>
              </div>
            </div>
            <div class="mb-4">
              <div class="form-check">
                <input class="form-check-input" type="checkbox" name="termos" id="termos" required>
                <label class="form-check-label auth-check-label" for="termos">
                  Concordo com os Termos de Uso e Política de Privacidade
                </label>
              </div>
            </div>
            <button type="submit" class="btn btn-primary w-100 auth-btn">Criar conta</button>
          </form>

          <p class="auth-footer-text text-center mb-0 mt-4">
            Já tem conta? <a href="/login" class="auth-link">Fazer login</a>
          </p>
        </div>
      </div>

    </div>
  </div>

</body>
</html>
